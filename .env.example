# EVzone Rides Admin - Environment Configuration

# Backend API origin (must include /api/v1 prefix)
VITE_BACKEND_BASE_URL=http://localhost:3000/api/v1

# Socket.IO origin and path
VITE_SOCKET_BASE_URL=http://localhost:3000
VITE_SOCKET_PATH=/socket.io

# Enable backend integration
VITE_BACKEND_ENABLED=true

# Google Maps browser API key, if map features require one.
# Do not commit a real key. Put local values in .env.local and deployment values in your hosting provider secrets.
VITE_GOOGLE_MAPS_API_KEY=

# Optional Google Cloud Map ID for vector maps.
VITE_GOOGLE_MAPS_MAP_ID=
